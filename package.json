{
  "name": "pubtab-js",
  "version": "0.1.0",
  "description": "TypeScript toolkit and dual-runtime package for converting tables between Excel and LaTeX. Inspired by Python module pubtab.",
  "packageManager": "pnpm@9.15.9",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "themes:generate": "node scripts/generate-theme-presets.mjs",
    "build": "tsc -p tsconfig.json",
    "dev": "vitest",
    "playground": "pnpm --dir playground dev",
    "build:playground": "pnpm --dir playground build",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "workspaces": [
    "playground"
  ],
  "keywords": [
    "latex",
    "excel",
    "xlsx",
    "table",
    "tabular",
    "cli"
  ],
  "author": "yuzh",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "bin": {
    "pubtab-js": "dist/cli.js"
  },
  "files": [
    "dist",
    "themes"
  ],
  "dependencies": {
    "exceljs": "^4.4.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "@types/node": "^25.4.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/browser-preview": "^4.0.18",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
