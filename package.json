{
  "name": "pubtab-node",
  "version": "0.1.0",
  "description": "TypeScript toolkit and CLI for converting tables between Excel and LaTeX. Inspired by Python module pubtab.",
  "packageManager": "pnpm@9.15.9",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "dev": "vitest",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "keywords": [
    "latex",
    "excel",
    "xlsx",
    "table",
    "tabular",
    "cli"
  ],
  "author": "yuzh",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pubtab-node": "dist/cli.js"
  },
  "files": [
    "dist",
    "themes"
  ],
  "dependencies": {
    "exceljs": "^4.4.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
